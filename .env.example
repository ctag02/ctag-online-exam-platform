# .env.example
# Secret key for signing JWT tokens (e.g., a long random string)
JWT_SECRET=ctag_secure_random_secret_2026

# Gemini API Key for PDF question extraction
# Use CUSTOM_GEMINI_API_KEY because GEMINI_API_KEY is reserved by the platform
CUSTOM_GEMINI_API_KEY=

# Environment settings
NODE_ENV=development
PORT=3000
