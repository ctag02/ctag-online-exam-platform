{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "role"]
    },
    "Question": {
      "title": "Question",
      "description": "Exam question",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "optionA": { "type": "string" },
        "optionB": { "type": "string" },
        "optionC": { "type": "string" },
        "optionD": { "type": "string" },
        "correctAnswer": { "type": "string", "enum": ["A", "B", "C", "D"] },
        "topic": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "optionA", "optionB", "optionC", "optionD", "correctAnswer"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Exam definition",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "duration": { "type": "integer" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "questionIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "duration", "scheduledAt", "isActive", "questionIds"]
    },
    "Response": {
      "title": "Response",
      "description": "Student response to a question",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "examId": { "type": "string" },
        "questionId": { "type": "string" },
        "answer": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "examId", "questionId", "answer"]
    },
    "Result": {
      "title": "Result",
      "description": "Exam result for a student",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "examId": { "type": "string" },
        "score": { "type": "number" },
        "correctCount": { "type": "integer" },
        "wrongCount": { "type": "integer" },
        "skippedCount": { "type": "integer" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "examTitle": { "type": "string" },
        "studentName": { "type": "string" },
        "studentEmail": { "type": "string" },
        "skippedTopicsCount": { "type": "integer" },
        "wrongTopicsCount": { "type": "integer" },
        "skippedTopicsList": { "type": "string" },
        "wrongTopicsList": { "type": "string" }
      },
      "required": ["userId", "examId", "score", "correctCount", "wrongCount", "skippedCount", "submittedAt"]
    },
    "WarningLog": {
      "title": "WarningLog",
      "description": "Log of exam warnings (e.g. tab switching)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "examId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "studentName": { "type": "string" }
      },
      "required": ["userId", "examId", "type", "message", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/questions/{questionId}": { "schema": "Question", "description": "Question bank" },
    "/exams/{examId}": { "schema": "Exam", "description": "Exam definitions" },
    "/exams/{examId}/responses/{responseId}": { "schema": "Response", "description": "Question responses" },
    "/results/{resultId}": { "schema": "Result", "description": "Exam results" },
    "/warning_logs/{logId}": { "schema": "WarningLog", "description": "Security warning logs" }
  }
}
